# Backend Configuration
# Copy this file to .env and adjust values as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=7892

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:1420,http://localhost:5173,http://localhost:5174

# Paths Configuration
# All paths are hardcoded and cannot be overridden:
# - Home:       ~/.kumiai
# - Agents:     ~/.kumiai/agents
# - Skills:     ~/.kumiai/skills
# - Projects:   ~/.kumiai/projects
# - Database:   ~/.kumiai/kumiAI.db

# Claude SDK Configuration
# CLAUDE_CWD=.
# CLAUDE_SETTING_SOURCES=project
